#!/bin/sh
set -e

#DEBHELPER#

case $1 in
    remove)
        conflicts="
        /usr/lib/modprobe.d/blacklist-qcom-camera.conf
        /etc/kernel/postinst.d/zzz-update-dtb
        "
        for i in $conflicts
        do
            dpkg-divert --package task-qualcomm --rename --remove "$i"
        done
        ;;
esac

exit 0
